<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd" extends="pagebuilder_base_form">
    <fieldset name="general" sortOrder="20">
        <field name="link_label" sortOrder="25" formElement="input">
            <settings>
                <label translate="true">Link Description</label>
                <notice translate="true">This should be descriptive to ensure Google's web vitals audits are passed; for example... "Buy" will fail; "Discover our new range of products" will pass</notice>
                <validation>
                    <rule name="validate-string" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
    </fieldset>
    <fieldset name="webvitals" sortOrder="40">
        <settings>
            <label translate="true">Web Vitals</label>
            <collapsible>true</collapsible>
            <opened>true</opened>
        </settings>
        <field name="wvwidth" sortOrder="10" formElement="input">
            <settings>
                <label translate="true">Image Width</label>
                <notice translate="true">Declaring image dimensions can drastically improve your rank on Google's web vitals audit</notice>
                <validation>
                    <rule name="validate-string" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <field name="wvheight" sortOrder="20" formElement="input">
            <settings>
                <label translate="true">Image Height</label>
                <notice translate="true">Declaring image dimensions can drastically improve your rank on Google's web vitals audit</notice>
                <validation>
                    <rule name="validate-string" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <field name="lazyload_image" sortOrder="30" formElement="checkbox">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="default" xsi:type="string">no</item>
                </item>
            </argument>
            <settings>
                <dataType>boolean</dataType>
                <label translate="true">Stop Image From Being Lazyily Loaded</label>
                <notice translate="true">Lazily loading your LCP (largest contentful paint) image will result in Google's Web Vitals audit reporting this as "Largest contentful paint image was lazily loaded". Stopping your LCP image will result in this image passing the audit and will help improve your LCP score</notice>
                <dataScope>lazyload_image</dataScope>
            </settings>
            <formElements>
                <checkbox>
                    <settings>
                        <valueMap>
                            <map name="false" xsi:type="string">no</map>
                            <map name="true" xsi:type="string">yes</map>
                        </valueMap>
                        <prefer>toggle</prefer>
                    </settings>
                </checkbox>
            </formElements>
        </field>
    </fieldset>
</form>
